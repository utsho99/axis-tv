import { motion } from 'framer-motion'
import { ExternalLink, ArrowUpRight } from 'lucide-react'

export default function FounderPage() {
  return (
    <div style={{paddingTop:'88px', minHeight:'100vh'}}>
      <div className="px-[4%] pb-20" style={{maxWidth:'800px'}}>
        <motion.div initial={{opacity:0,y:24}} animate={{opacity:1,y:0}} transition={{duration:0.6,ease:[0.16,1,0.3,1]}}>
          <p style={{fontSize:'11px',fontWeight:700,textTransform:'uppercase',letterSpacing:'0.22em',color:'#E50914',marginBottom:'20px'}}>Founder</p>
          <h1 style={{fontFamily:'"Barlow",sans-serif',fontSize:'clamp(3rem,8vw,6rem)',fontWeight:900,color:'white',lineHeight:0.9,letterSpacing:'-0.02em',marginBottom:'16px'}}>
            Aditya<br/><span style={{color:'rgba(255,255,255,0.35)',fontStyle:'italic'}}>Barma Utsho.</span>
          </h1>
          <p style={{fontSize:'20px',color:'rgba(255,255,255,0.5)',marginBottom:'32px',fontWeight:300}}>Designer. Founder. Builder.</p>
          <a href="https://adityabarma.netlify.app/" target="_blank" rel="noopener noreferrer"
            className="btn-red inline-flex items-center gap-2" style={{padding:'12px 28px',fontSize:'15px'}}>
            Portfolio <ExternalLink size={15}/>
          </a>
        </motion.div>

        <motion.div initial={{opacity:0}} animate={{opacity:1}} transition={{delay:0.2}}
          style={{borderTop:'1px solid rgba(255,255,255,0.07)',marginTop:'60px',paddingTop:'48px'}}>
          <p style={{fontSize:'11px',fontWeight:700,textTransform:'uppercase',letterSpacing:'0.22em',color:'rgba(255,255,255,0.3)',marginBottom:'32px'}}>Ventures</p>
          <div style={{display:'flex',flexDirection:'column',gap:'12px'}}>
            {[
              {name:'AXIS',tag:'Streaming Platform',color:'#E50914',desc:'A premium streaming workspace. Not an IPTV player — a platform built around the experience of watching beautifully.'},
              {name:'Aether Works',tag:'Digital Studio',color:'#0071EB',desc:'A digital studio crafting purposeful web experiences and products that are built to last.'},
              {name:'Vidraze Studio',tag:'Creative Design',color:'#7C3AED',desc:'A creative practice focused on visual identity, motion design, and making things look extraordinary.'},
            ].map(({name,tag,color,desc},i)=>(
              <motion.div key={name} initial={{opacity:0,x:-16}} animate={{opacity:1,x:0}} transition={{delay:0.3+i*0.1}}
                style={{background:'rgba(255,255,255,0.03)',border:'1px solid rgba(255,255,255,0.07)',borderRadius:'8px',padding:'24px',cursor:'pointer',transition:'border-color 0.2s'}}
                onMouseEnter={e=>(e.currentTarget.style.borderColor=color+'50')}
                onMouseLeave={e=>(e.currentTarget.style.borderColor='rgba(255,255,255,0.07)')}>
                <div style={{height:'3px',background:color,borderRadius:'2px',marginBottom:'16px',width:'32px'}}/>
                <div className="flex items-start justify-between">
                  <div>
                    <h3 style={{fontFamily:'"Barlow",sans-serif',fontSize:'22px',fontWeight:800,color:'white',marginBottom:'4px'}}>{name}</h3>
                    <span style={{fontSize:'11px',fontWeight:700,textTransform:'uppercase',letterSpacing:'0.12em',color:color,background:`${color}18`,padding:'3px 10px',borderRadius:'3px'}}>{tag}</span>
                    <p style={{fontSize:'14px',color:'rgba(255,255,255,0.45)',marginTop:'12px',lineHeight:1.6}}>{desc}</p>
                  </div>
                  <ArrowUpRight size={18} style={{color:'rgba(255,255,255,0.2)',flexShrink:0,marginTop:'4px'}}/>
                </div>
              </motion.div>
            ))}
          </div>
        </motion.div>

        <motion.div initial={{opacity:0}} animate={{opacity:1}} transition={{delay:0.5}}
          style={{borderTop:'1px solid rgba(255,255,255,0.07)',marginTop:'60px',paddingTop:'48px'}}>
          <p style={{fontSize:'11px',fontWeight:700,textTransform:'uppercase',letterSpacing:'0.22em',color:'rgba(255,255,255,0.3)',marginBottom:'24px'}}>Philosophy</p>
          <blockquote style={{fontFamily:'"Barlow",sans-serif',fontSize:'clamp(1.5rem,3vw,2.2rem)',fontWeight:800,color:'white',lineHeight:1.2,marginBottom:'24px'}}>
            "Most things are designed to be good enough.<br/>
            <span style={{color:'rgba(255,255,255,0.35)',fontStyle:'italic'}}>I build things to be remarkable."</span>
          </blockquote>
          <p style={{fontSize:'15px',color:'rgba(255,255,255,0.4)',lineHeight:1.8,maxWidth:'560px'}}>
            Every project starts with one question: what would make this truly unforgettable?
